# ============================================================
# xRay_Detection — Environment Variables
# Copy to .env and adjust for your environment.
# ============================================================

# ---- API (FastAPI inference service) ----
# Path (inside the api container) to the trained YOLO weights.
# We default to ONNX (smaller, faster, no PyTorch runtime needed).
# Switch to best.pt if you want the PyTorch format.
MODEL_PATH=/app/weights/best.onnx

# Inference provider:
# - local: use MODEL_PATH
# - roboflow: use a hosted Roboflow Universe model, useful for a stronger client demo
INFERENCE_PROVIDER=local

# Roboflow hosted model option. Set INFERENCE_PROVIDER=roboflow and add your key.
# This ready model is listed on Roboflow Universe with mAP@50 around 94%.
ROBOFLOW_MODEL_ID=x-ray-baggage-rkyb4/3
ROBOFLOW_API_KEY=
ROBOFLOW_API_BASE=https://serverless.roboflow.com

# Detection thresholds
CONF_THRESHOLD=0.20
IOU_THRESHOLD=0.45

# CORS — comma-separated list of allowed origins for the web UI
ALLOWED_ORIGINS=http://localhost:3030,http://localhost:3000

# Port the API listens on (inside the container)
API_PORT=8000

# ---- Web (Next.js frontend) ----
# Public URL of the API — must be reachable from the browser.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Host port for the web UI (the container always listens on 3000 internally).
# Default 3030 to avoid conflicts with other projects that occupy 3000.
WEB_PORT=3030

# Default locale ('ar' | 'en')
NEXT_PUBLIC_DEFAULT_LOCALE=ar
